{
  "$schema": "https://opencode.ai/config.json",

  "agent": {
    "build": {
      "tools": {
        "skill": true
      }
    }
  },

  "command": {
    "test": {
      "template": "Run `python -m pytest tests/ -v` and report results.",
      "description": "Run reverse-abliterate tests"
    },
    "scan": {
      "template": "Run `reverse-abliterate scan <path>` to scan a model directory.",
      "description": "Check model for abliteration",
      "arguments": [
        {
          "name": "path",
          "description": "Path to model directory",
          "required": true
        }
      ]
    },
    "manifest": {
      "template": "Generate a weight integrity manifest for a model.",
      "description": "Generate weight manifest",
      "arguments": [
        {
          "name": "path",
          "description": "Path to model directory",
          "required": true
        }
      ]
    },
    "harden": {
      "template": "Generate a hardening report for a model.",
      "description": "Generate hardening report",
      "arguments": [
        {
          "name": "path",
          "description": "Path to model directory",
          "required": true
        }
      ]
    }
  }
}
